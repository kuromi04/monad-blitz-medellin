# Variables de entorno para dApps con RainbowKit + wagmi
# Copia este archivo como .env y rellena los valores

# WalletConnect Project ID — obtener en https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# RPC del chain que uses (Alchemy, Infura, RPC público, etc.)
# Ejemplos:
#   Monad Testnet (Alchemy): https://monad-testnet.g.alchemy.com/v2/<API_KEY>
#   Sepolia (Alchemy):       https://eth-sepolia.g.alchemy.com/v2/<API_KEY>
#   Base Sepolia (Alchemy):  https://base-sepolia.g.alchemy.com/v2/<API_KEY>
VITE_CHAIN_RPC_URL=

# Contratos desplegados — una variable por contrato
# VITE_STORAGE_CONTRACT_ADDRESS=0x...
# VITE_TODOLIST_CONTRACT_ADDRESS=0x...
# VITE_TOKEN_CONTRACT_ADDRESS=0x...
